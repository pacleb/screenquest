{
  "name": "screenquest",
  "private": true,
  "version": "0.0.1",
  "description": "ScreenQuest - Kids earn screen time by completing real-world quests",
  "scripts": {
    "backend:dev": "pnpm --filter backend dev",
    "backend:build": "pnpm --filter backend build",
    "backend:start": "pnpm --filter backend start:prod",
    "mobile:start": "pnpm --filter mobile start",
    "mobile:ios": "pnpm --filter mobile ios",
    "mobile:android": "pnpm --filter mobile android",
    "cms:dev": "pnpm --filter cms dev",
    "db:migrate": "pnpm --filter backend prisma:migrate",
    "db:seed": "pnpm --filter backend prisma:seed",
    "db:studio": "pnpm --filter backend prisma:studio",
    "test": "pnpm --filter backend test",
    "test:e2e": "pnpm --filter backend test:e2e",
    "test:all": "pnpm --filter backend test:all",
    "test:cov": "pnpm --filter backend test:cov",
    "lint": "pnpm --filter backend exec tsc --noEmit",
    "android": "pnpm --filter mobile android",
    "ios": "pnpm --filter mobile ios",
    "mobile:e2e:ios:build": "pnpm --filter mobile e2e:ios:build",
    "mobile:e2e:ios": "pnpm --filter mobile e2e:ios",
    "mobile:e2e:android:build": "pnpm --filter mobile e2e:android:build",
    "mobile:e2e:android": "pnpm --filter mobile e2e:android"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "detox",
      "prisma",
      "sharp",
      "@sentry/cli"
    ],
    "overrides": {}
  },
  "dependencies": {
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
