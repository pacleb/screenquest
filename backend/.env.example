# ──────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────
DATABASE_URL="postgresql://screenquest:screenquest@localhost:5432/screenquest?schema=public"
# Direct connection URL (required for Supabase; for local Docker, same as DATABASE_URL)
DIRECT_URL="postgresql://screenquest:screenquest@localhost:5432/screenquest?schema=public"

# ──────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ──────────────────────────────────────────────
# JWT Authentication
# ──────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="30d"

# ──────────────────────────────────────────────
# App / Server
# ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:8081"
CMS_URL="http://localhost:3001"

# ──────────────────────────────────────────────
# Email (Resend)
# ──────────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="noreply@screenquest.app"

# ──────────────────────────────────────────────
# File Storage (S3 / R2)
# Leave blank for local disk storage in development
# ──────────────────────────────────────────────
AWS_S3_BUCKET=""
AWS_S3_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ──────────────────────────────────────────────
# Error Tracking (Sentry)
# ──────────────────────────────────────────────
SENTRY_DSN=""

# ──────────────────────────────────────────────
# Analytics (PostHog)
# Disabled when POSTHOG_API_KEY is not set
# ──────────────────────────────────────────────
POSTHOG_API_KEY=""
POSTHOG_HOST="https://us.i.posthog.com"

# ──────────────────────────────────────────────
# Subscriptions (RevenueCat)
# ──────────────────────────────────────────────
REVENUECAT_WEBHOOK_AUTH_KEY=""
# Secret API key for server-side RevenueCat REST API calls (e.g. subscription sync)
REVENUECAT_SECRET_KEY=""
