generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Family {
  id                    String    @id @default(uuid()) @db.Uuid
  name                  String    @db.VarChar(100)
  familyCode            String    @unique @map("family_code") @db.VarChar(8)
  plan                  String    @default("free") @db.VarChar(20)
  subscriptionStatus    String?   @map("subscription_status") @db.VarChar(20)
  subscriptionExpiresAt DateTime? @map("subscription_expires_at") @db.Timestamptz()
  subscriptionPeriod    String?   @map("subscription_period") @db.VarChar(10)
  gracePeriodEndsAt     DateTime? @map("grace_period_ends_at") @db.Timestamptz()
  revenuecatAppUserId   String?   @map("revenuecat_app_user_id") @db.VarChar(255)
  leaderboardEnabled    Boolean   @default(false) @map("leaderboard_enabled")
  ownerId               String?   @map("owner_id") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  owner   User?          @relation("FamilyOwner", fields: [ownerId], references: [id])
  members User[]         @relation("FamilyMembers")
  invites FamilyInvite[]
  quests  Quest[]

  @@map("families")
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  email          String?  @unique @db.VarChar(255)
  passwordHash   String?  @map("password_hash") @db.VarChar(255)
  name           String   @db.VarChar(100)
  avatarUrl      String?  @map("avatar_url") @db.VarChar(500)
  role           String   @db.VarChar(20)
  familyId       String?  @map("family_id") @db.Uuid
  pin            String?  @db.VarChar(255)
  age            Int?
  authProvider   String   @default("email") @map("auth_provider") @db.VarChar(20)
  authProviderId String?  @map("auth_provider_id") @db.VarChar(255)
  isAppAdmin     Boolean  @default(false) @map("is_app_admin")
  emailVerified  Boolean  @default(false) @map("email_verified")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  guardianPermissions Json?   @map("guardian_permissions") @db.JsonB
  playSettings        Json?   @map("play_settings") @db.JsonB
  activeThemeId       String? @map("active_theme_id") @db.Uuid

  family            Family?           @relation("FamilyMembers", fields: [familyId], references: [id])
  ownedFamilies     Family[]          @relation("FamilyOwner")
  refreshTokens     RefreshToken[]
  invitesSent       FamilyInvite[]
  createdQuests        Quest[]           @relation("QuestCreator")
  questAssignments     QuestAssignment[] @relation("ChildAssignments")
  completions          QuestCompletion[] @relation("ChildCompletions")
  approvedCompletions  QuestCompletion[] @relation("ApprovedCompletions")
  timeBank             TimeBank?         @relation("ChildTimeBank")
  playSessions         PlaySession[]     @relation("ChildPlaySessions")
  approvedSessions     PlaySession[]     @relation("ApprovedPlaySessions")
  violations           Violation[]       @relation("ChildViolations")
  recordedViolations   Violation[]       @relation("RecordedViolations")
  violationCounter     ViolationCounter? @relation("ChildViolationCounter")
  pushTokens           PushToken[]
  notificationPrefs    NotificationPreference? @relation("UserNotificationPrefs")
  avatarPacks          AvatarPackPurchase[]
  progress             ChildProgress?        @relation("ChildProgress")
  childAchievements    ChildAchievement[]    @relation("ChildAchievements")
  equippedItems        ChildEquippedItem[]   @relation("ChildEquippedItems")
  activeTheme          Theme?                @relation("UserActiveTheme", fields: [activeThemeId], references: [id])
  childConsents        ParentalConsent[]     @relation("ChildConsent")
  parentConsents       ParentalConsent[]     @relation("ParentConsent")
  deletionRequests     AccountDeletionRequest[] @relation("UserDeletionRequest")
  policyAcceptances    PolicyAcceptance[]    @relation("UserPolicyAcceptances")

  @@map("users")
}

model FamilyInvite {
  id            String   @id @default(uuid()) @db.Uuid
  familyId      String   @map("family_id") @db.Uuid
  invitedByUserId String @map("invited_by_user_id") @db.Uuid
  inviteEmail   String   @map("invite_email") @db.VarChar(255)
  role          String   @default("guardian") @db.VarChar(20)
  status        String   @default("pending") @db.VarChar(20)
  expiresAt     DateTime @map("expires_at") @db.Timestamptz()
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  family    Family @relation(fields: [familyId], references: [id])
  invitedBy User   @relation(fields: [invitedByUserId], references: [id])

  @@map("family_invites")
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @map("token_hash") @db.VarChar(255)
  deviceInfo String?  @map("device_info") @db.VarChar(255)
  expiresAt  DateTime @map("expires_at") @db.Timestamptz()
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model QuestLibrary {
  id                    String   @id @default(uuid()) @db.Uuid
  name                  String   @db.VarChar(200)
  description           String?  @db.Text
  icon                  String?  @db.VarChar(50)
  category              String   @db.VarChar(50)
  suggestedRewardSeconds Int     @map("suggested_reward_seconds")
  suggestedStackingType String   @default("stackable") @map("suggested_stacking_type") @db.VarChar(20)
  ageRange              String?  @map("age_range") @db.VarChar(20)
  isPublished           Boolean  @default(false) @map("is_published")
  sortOrder             Int      @default(0) @map("sort_order")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  familyQuests Quest[]

  @@map("quest_library")
}

model Quest {
  id              String   @id @default(uuid()) @db.Uuid
  familyId        String   @map("family_id") @db.Uuid
  createdByUserId String   @map("created_by_user_id") @db.Uuid
  libraryQuestId  String?  @map("library_quest_id") @db.Uuid
  name            String   @db.VarChar(200)
  description     String?  @db.Text
  icon            String   @default("⭐") @db.VarChar(50)
  category        String   @db.VarChar(50)
  rewardSeconds   Int      @map("reward_seconds")
  stackingType    String   @map("stacking_type") @db.VarChar(20)
  recurrence      String   @default("one_time") @db.VarChar(20)
  recurrenceDays  Json?    @map("recurrence_days") @db.JsonB
  requiresProof   Boolean  @default(false) @map("requires_proof")
  autoApprove     Boolean  @default(true) @map("auto_approve")
  bonusMultiplier Float    @default(1.0) @map("bonus_multiplier")
  isArchived      Boolean  @default(false) @map("is_archived")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  family       Family           @relation(fields: [familyId], references: [id])
  createdBy    User             @relation("QuestCreator", fields: [createdByUserId], references: [id])
  libraryQuest QuestLibrary?    @relation(fields: [libraryQuestId], references: [id])
  assignments  QuestAssignment[]
  completions  QuestCompletion[]

  @@map("quests")
}

model QuestAssignment {
  id      String @id @default(uuid()) @db.Uuid
  questId String @map("quest_id") @db.Uuid
  childId String @map("child_id") @db.Uuid

  quest Quest @relation(fields: [questId], references: [id], onDelete: Cascade)
  child User  @relation("ChildAssignments", fields: [childId], references: [id])

  @@unique([questId, childId])
  @@map("quest_assignments")
}

model QuestCompletion {
  id               String    @id @default(uuid()) @db.Uuid
  questId          String    @map("quest_id") @db.Uuid
  childId          String    @map("child_id") @db.Uuid
  status           String    @default("pending") @db.VarChar(20)
  proofImageUrl    String?   @map("proof_image_url") @db.VarChar(500)
  approvedByUserId String?   @map("approved_by_user_id") @db.Uuid
  earnedSeconds    Int       @map("earned_seconds")
  stackingType     String    @map("stacking_type") @db.VarChar(20)
  expiresAt        DateTime? @map("expires_at") @db.Timestamptz()
  parentNote       String?   @map("parent_note") @db.Text
  completedAt      DateTime  @default(now()) @map("completed_at") @db.Timestamptz()
  reviewedAt       DateTime? @map("reviewed_at") @db.Timestamptz()

  quest      Quest @relation(fields: [questId], references: [id])
  child      User  @relation("ChildCompletions", fields: [childId], references: [id])
  approvedBy User? @relation("ApprovedCompletions", fields: [approvedByUserId], references: [id])

  @@map("quest_completions")
}

model TimeBank {
  id                         String   @id @default(uuid()) @db.Uuid
  childId                    String   @unique @map("child_id") @db.Uuid
  stackableBalanceSeconds    Int      @default(0) @map("stackable_balance_seconds")
  nonStackableBalanceSeconds Int      @default(0) @map("non_stackable_balance_seconds")
  lastUpdated                DateTime @default(now()) @map("last_updated") @db.Timestamptz()

  child User @relation("ChildTimeBank", fields: [childId], references: [id])

  @@map("time_banks")
}

model PlaySession {
  id                 String    @id @default(uuid()) @db.Uuid
  childId            String    @map("child_id") @db.Uuid
  requestedSeconds   Int       @map("requested_seconds")
  status             String    @default("requested") @db.VarChar(20)
  approvedByUserId   String?   @map("approved_by_user_id") @db.Uuid
  startedAt          DateTime? @map("started_at") @db.Timestamptz()
  pausedAt           DateTime? @map("paused_at") @db.Timestamptz()
  totalPausedSeconds Int       @default(0) @map("total_paused_seconds")
  endedAt            DateTime? @map("ended_at") @db.Timestamptz()
  lastSyncedAt       DateTime? @map("last_synced_at") @db.Timestamptz()
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  child      User  @relation("ChildPlaySessions", fields: [childId], references: [id])
  approvedBy User? @relation("ApprovedPlaySessions", fields: [approvedByUserId], references: [id])

  @@map("play_sessions")
}

model Violation {
  id               String   @id @default(uuid()) @db.Uuid
  childId          String   @map("child_id") @db.Uuid
  recordedByUserId String   @map("recorded_by_user_id") @db.Uuid
  violationNumber  Int      @map("violation_number")
  penaltySeconds   Int      @map("penalty_seconds")
  description      String?  @db.Text
  forgiven         Boolean  @default(false)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz()

  child      User @relation("ChildViolations", fields: [childId], references: [id])
  recordedBy User @relation("RecordedViolations", fields: [recordedByUserId], references: [id])

  @@map("violations")
}

model ViolationCounter {
  childId      String    @id @map("child_id") @db.Uuid
  currentCount Int       @default(0) @map("current_count")
  lastResetAt  DateTime? @map("last_reset_at") @db.Timestamptz()
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz()

  child User @relation("ChildViolationCounter", fields: [childId], references: [id])

  @@map("violation_counters")
}

model PushToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  token     String   @db.VarChar(500)
  platform  String   @db.VarChar(10)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, token])
  @@map("push_tokens")
}

model AvatarPackPurchase {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  packId    String   @map("pack_id") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, packId])
  @@map("avatar_pack_purchases")
}

model QuestCategory {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(50)
  icon      String?  @db.VarChar(50)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  @@map("quest_categories")
}

model ChildProgress {
  childId            String    @id @map("child_id") @db.Uuid
  totalXp            Int       @default(0) @map("total_xp")
  level              Int       @default(1)
  currentStreak      Int       @default(0) @map("current_streak")
  longestStreak      Int       @default(0) @map("longest_streak")
  lastCompletionDate DateTime? @map("last_completion_date") @db.Date
  weeklyXp           Int       @default(0) @map("weekly_xp")
  weeklyXpResetAt    DateTime? @map("weekly_xp_reset_at") @db.Timestamptz()
  showcaseBadges     String[]  @default([]) @map("showcase_badges") @db.Uuid
  streakFreezeUsedAt DateTime? @map("streak_freeze_used_at") @db.Timestamptz()
  updatedAt          DateTime  @default(now()) @map("updated_at") @db.Timestamptz()

  child User @relation("ChildProgress", fields: [childId], references: [id])

  @@map("child_progress")
}

model Achievement {
  id            String   @id @default(uuid()) @db.Uuid
  key           String   @unique @db.VarChar(50)
  name          String   @db.VarChar(100)
  description   String   @db.VarChar(255)
  icon          String   @db.VarChar(50)
  category      String   @db.VarChar(50)
  criteria      Json     @db.JsonB
  sortOrder     Int      @default(0) @map("sort_order")
  badgeTier     String   @default("bronze") @map("badge_tier") @db.VarChar(10)
  badgeColor    String   @default("#CD7F32") @map("badge_color") @db.VarChar(7)
  xpReward      Int      @default(0) @map("xp_reward")
  isSecret      Boolean  @default(false) @map("is_secret")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  childAchievements ChildAchievement[]

  @@map("achievements")
}

model ChildAchievement {
  id            String   @id @default(uuid()) @db.Uuid
  childId       String   @map("child_id") @db.Uuid
  achievementId String   @map("achievement_id") @db.Uuid
  unlockedAt    DateTime @default(now()) @map("unlocked_at") @db.Timestamptz()

  child       User        @relation("ChildAchievements", fields: [childId], references: [id])
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@unique([childId, achievementId])
  @@map("child_achievements")
}

model AvatarItem {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  icon        String   @db.VarChar(50)
  slot        String   @db.VarChar(20)
  unlockType  String   @map("unlock_type") @db.VarChar(20)
  unlockValue String?  @map("unlock_value") @db.VarChar(100)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  equippedBy ChildEquippedItem[]

  @@map("avatar_items")
}

model ChildEquippedItem {
  id           String   @id @default(uuid()) @db.Uuid
  childId      String   @map("child_id") @db.Uuid
  avatarItemId String   @map("avatar_item_id") @db.Uuid
  slot         String   @db.VarChar(20)
  equippedAt   DateTime @default(now()) @map("equipped_at") @db.Timestamptz()

  child      User       @relation("ChildEquippedItems", fields: [childId], references: [id])
  avatarItem AvatarItem @relation(fields: [avatarItemId], references: [id])

  @@unique([childId, slot])
  @@map("child_equipped_items")
}

model NotificationPreference {
  userId           String   @id @map("user_id") @db.Uuid
  questCompletions Boolean  @default(true) @map("quest_completions")
  playRequests     Boolean  @default(true) @map("play_requests")
  playStateChanges Boolean  @default(true) @map("play_state_changes")
  violations       Boolean  @default(true)
  dailySummary     Boolean  @default(true) @map("daily_summary")
  weeklySummary    Boolean  @default(true) @map("weekly_summary")
  gamification     Boolean  @default(true)
  updatedAt        DateTime @default(now()) @map("updated_at") @db.Timestamptz()

  user User @relation("UserNotificationPrefs", fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model Theme {
  id          String   @id @default(uuid()) @db.Uuid
  key         String   @unique @db.VarChar(50)
  name        String   @db.VarChar(100)
  description String   @db.VarChar(255)
  previewUrl  String?  @map("preview_url") @db.VarChar(500)
  unlockType  String   @map("unlock_type") @db.VarChar(20)
  unlockValue Int?     @map("unlock_value")
  colors      Json     @db.JsonB
  gradients   Json?    @db.JsonB
  isAnimated  Boolean  @default(false) @map("is_animated")
  category    String   @db.VarChar(30)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz()

  users User[] @relation("UserActiveTheme")

  @@map("themes")
}

model ParentalConsent {
  id          String    @id @default(uuid()) @db.Uuid
  childId     String    @map("child_id") @db.Uuid
  parentId    String    @map("parent_id") @db.Uuid
  consentText String    @map("consent_text") @db.Text
  consentedAt DateTime  @default(now()) @map("consented_at") @db.Timestamptz()
  ipAddress   String?   @map("ip_address") @db.VarChar(45)
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz()

  child  User @relation("ChildConsent", fields: [childId], references: [id])
  parent User @relation("ParentConsent", fields: [parentId], references: [id])

  @@map("parental_consents")
}

model AccountDeletionRequest {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  requestedAt       DateTime  @default(now()) @map("requested_at") @db.Timestamptz()
  gracePeriodEndsAt DateTime  @map("grace_period_ends_at") @db.Timestamptz()
  cancelledAt       DateTime? @map("cancelled_at") @db.Timestamptz()
  purgedAt          DateTime? @map("purged_at") @db.Timestamptz()
  reason            String?   @db.VarChar(500)

  user User @relation("UserDeletionRequest", fields: [userId], references: [id])

  @@map("account_deletion_requests")
}

model DeletionAuditLog {
  id               String   @id @default(uuid()) @db.Uuid
  anonymizedHash   String   @map("anonymized_hash") @db.VarChar(64)
  deletionDate     DateTime @default(now()) @map("deletion_date") @db.Timestamptz()
  dataTypesDeleted String[] @map("data_types_deleted")
  userRole         String   @map("user_role") @db.VarChar(20)

  @@map("deletion_audit_logs")
}

model PolicyAcceptance {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  documentType    String   @map("document_type") @db.VarChar(30)
  documentVersion String   @map("document_version") @db.VarChar(20)
  acceptedAt      DateTime @default(now()) @map("accepted_at") @db.Timestamptz()
  ipAddress       String?  @map("ip_address") @db.VarChar(45)

  user User @relation("UserPolicyAcceptances", fields: [userId], references: [id])

  @@unique([userId, documentType, documentVersion])
  @@map("policy_acceptances")
}
