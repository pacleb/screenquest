generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Family {
  id                    String    @id @default(uuid()) @db.Uuid
  name                  String    @db.VarChar(100)
  familyCode            String    @unique @map("family_code") @db.VarChar(8)
  plan                  String    @default("free") @db.VarChar(20)
  subscriptionExpiresAt DateTime? @map("subscription_expires_at") @db.Timestamptz()
  subscriptionPeriod    String?   @map("subscription_period") @db.VarChar(10)
  ownerId               String?   @map("owner_id") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz()

  owner   User?          @relation("FamilyOwner", fields: [ownerId], references: [id])
  members User[]         @relation("FamilyMembers")
  invites FamilyInvite[]
  quests  Quest[]

  @@map("families")
}

model User {
  id             String   @id @default(uuid()) @db.Uuid
  email          String?  @unique @db.VarChar(255)
  passwordHash   String?  @map("password_hash") @db.VarChar(255)
  name           String   @db.VarChar(100)
  avatarUrl      String?  @map("avatar_url") @db.VarChar(500)
  role           String   @db.VarChar(20)
  familyId       String?  @map("family_id") @db.Uuid
  pin            String?  @db.VarChar(6)
  age            Int?
  authProvider   String   @default("email") @map("auth_provider") @db.VarChar(20)
  authProviderId String?  @map("auth_provider_id") @db.VarChar(255)
  emailVerified  Boolean  @default(false) @map("email_verified")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  guardianPermissions Json?   @map("guardian_permissions") @db.JsonB

  family            Family?           @relation("FamilyMembers", fields: [familyId], references: [id])
  ownedFamilies     Family[]          @relation("FamilyOwner")
  refreshTokens     RefreshToken[]
  invitesSent       FamilyInvite[]
  createdQuests        Quest[]           @relation("QuestCreator")
  questAssignments     QuestAssignment[] @relation("ChildAssignments")
  completions          QuestCompletion[] @relation("ChildCompletions")
  approvedCompletions  QuestCompletion[] @relation("ApprovedCompletions")
  timeBank             TimeBank?         @relation("ChildTimeBank")

  @@map("users")
}

model FamilyInvite {
  id            String   @id @default(uuid()) @db.Uuid
  familyId      String   @map("family_id") @db.Uuid
  invitedByUserId String @map("invited_by_user_id") @db.Uuid
  inviteEmail   String   @map("invite_email") @db.VarChar(255)
  role          String   @default("guardian") @db.VarChar(20)
  status        String   @default("pending") @db.VarChar(20)
  expiresAt     DateTime @map("expires_at") @db.Timestamptz()
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  family    Family @relation(fields: [familyId], references: [id])
  invitedBy User   @relation(fields: [invitedByUserId], references: [id])

  @@map("family_invites")
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @map("token_hash") @db.VarChar(255)
  deviceInfo String?  @map("device_info") @db.VarChar(255)
  expiresAt  DateTime @map("expires_at") @db.Timestamptz()
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model QuestLibrary {
  id                    String   @id @default(uuid()) @db.Uuid
  name                  String   @db.VarChar(200)
  description           String?  @db.Text
  icon                  String?  @db.VarChar(50)
  category              String   @db.VarChar(50)
  suggestedRewardMinutes Int     @map("suggested_reward_minutes")
  suggestedStackingType String   @default("stackable") @map("suggested_stacking_type") @db.VarChar(20)
  ageRange              String?  @map("age_range") @db.VarChar(20)
  isPublished           Boolean  @default(false) @map("is_published")
  sortOrder             Int      @default(0) @map("sort_order")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  familyQuests Quest[]

  @@map("quest_library")
}

model Quest {
  id              String   @id @default(uuid()) @db.Uuid
  familyId        String   @map("family_id") @db.Uuid
  createdByUserId String   @map("created_by_user_id") @db.Uuid
  libraryQuestId  String?  @map("library_quest_id") @db.Uuid
  name            String   @db.VarChar(200)
  description     String?  @db.Text
  icon            String   @default("⭐") @db.VarChar(50)
  category        String   @db.VarChar(50)
  rewardMinutes   Int      @map("reward_minutes")
  stackingType    String   @map("stacking_type") @db.VarChar(20)
  recurrence      String   @default("one_time") @db.VarChar(20)
  recurrenceDays  Json?    @map("recurrence_days") @db.JsonB
  requiresProof   Boolean  @default(false) @map("requires_proof")
  autoApprove     Boolean  @default(false) @map("auto_approve")
  bonusMultiplier Float    @default(1.0) @map("bonus_multiplier")
  isArchived      Boolean  @default(false) @map("is_archived")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  family       Family           @relation(fields: [familyId], references: [id])
  createdBy    User             @relation("QuestCreator", fields: [createdByUserId], references: [id])
  libraryQuest QuestLibrary?    @relation(fields: [libraryQuestId], references: [id])
  assignments  QuestAssignment[]
  completions  QuestCompletion[]

  @@map("quests")
}

model QuestAssignment {
  id      String @id @default(uuid()) @db.Uuid
  questId String @map("quest_id") @db.Uuid
  childId String @map("child_id") @db.Uuid

  quest Quest @relation(fields: [questId], references: [id], onDelete: Cascade)
  child User  @relation("ChildAssignments", fields: [childId], references: [id])

  @@unique([questId, childId])
  @@map("quest_assignments")
}

model QuestCompletion {
  id               String    @id @default(uuid()) @db.Uuid
  questId          String    @map("quest_id") @db.Uuid
  childId          String    @map("child_id") @db.Uuid
  status           String    @default("pending") @db.VarChar(20)
  proofImageUrl    String?   @map("proof_image_url") @db.VarChar(500)
  approvedByUserId String?   @map("approved_by_user_id") @db.Uuid
  earnedMinutes    Int       @map("earned_minutes")
  stackingType     String    @map("stacking_type") @db.VarChar(20)
  expiresAt        DateTime? @map("expires_at") @db.Timestamptz()
  parentNote       String?   @map("parent_note") @db.Text
  completedAt      DateTime  @default(now()) @map("completed_at") @db.Timestamptz()
  reviewedAt       DateTime? @map("reviewed_at") @db.Timestamptz()

  quest      Quest @relation(fields: [questId], references: [id])
  child      User  @relation("ChildCompletions", fields: [childId], references: [id])
  approvedBy User? @relation("ApprovedCompletions", fields: [approvedByUserId], references: [id])

  @@map("quest_completions")
}

model TimeBank {
  id                         String   @id @default(uuid()) @db.Uuid
  childId                    String   @unique @map("child_id") @db.Uuid
  stackableBalanceMinutes    Int      @default(0) @map("stackable_balance_minutes")
  nonStackableBalanceMinutes Int      @default(0) @map("non_stackable_balance_minutes")
  lastUpdated                DateTime @default(now()) @map("last_updated") @db.Timestamptz()

  child User @relation("ChildTimeBank", fields: [childId], references: [id])

  @@map("time_banks")
}
